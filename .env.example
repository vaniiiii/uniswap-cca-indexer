ENVIO_API_TOKEN=        # Required for HyperSync access
BASE_RPC_URL=           # Base mainnet RPC (e.g. https://base-mainnet.g.alchemy.com/v2/YOUR_KEY)
ARB_RPC_URL=            # Arbitrum mainnet RPC (e.g. https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY)
ETH_RPC_URL=            # Ethereum mainnet RPC (e.g. https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY)
UNICHAIN_RPC_URL=       # Unichain mainnet RPC (e.g. https://unichain-mainnet.g.alchemy.com/v2/YOUR_KEY)

# Effect call rate limits (requests per second). Defaults shown here match code defaults.
# Conservative for free-tier RPCs. Increase gradually (+1 every few runs) and watch 429 rate.
EFFECT_RPS_READ_TOTAL_SUPPLY=2
EFFECT_RPS_READ_AUCTION_SNAPSHOT=1
EFFECT_RPS_READ_STEPS=1
EFFECT_RPS_READ_CHECKPOINT_BUNDLE=6
EFFECT_RPS_READ_TICK_AT_BLOCK=3
EFFECT_RPS_READ_TICK_PAIR=6
